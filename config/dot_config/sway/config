# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

# Include default configs.
include /etc/sway/config.d/*

### Variables =================================================================
# Variables can not be included in a `include` file since that does not set the
# parent scopes.

# Main modification key:
# See `programmer` file.
# Use Mod1 for Alt.
# Use Mod2 for Super.
set $mod Mod1

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

# Your preferred terminal emulator
# ==================================================
set $term gabyx::term
# A wrapper script to start the terminal with additional env. variables.
set $term-start gabyx::term-start
# ==================================================

# Note: pass the final command to swaymsg so that the resulting window can be opened
# on the original workspace that the command was run on.

set $file-manager gabyx::file-manager-menu
set $display-manager gabyx::display-manager
set $launcher-menu gabyx::launcher-menu
set $power-menu gabyx::power-menu
set $wireless-menu gabyx::wireless-menu
set $network-menu gabyx::network-menu
set $bluetooth-menu gabyx::bluetooth-menu
set $emoji-menu gabyx::emoji-menu
set $systemd-menu gabyx::systemd-menu
set $procs-menu gabyx::procs-menu
set $sound-menu gabyx::sound-menu
set $calculator-menu gabyx::calculator-menu
set $screenshot-menu gabyx::screenshot-menu
set $screenrecord-menu gabyx::screenrecord-menu
set $color-picker-menu gabyx::color-picker-menu
set $clipboard-menu gabyx::clipboard-menu

set $brightness-up gabyx::brightness-up
set $brightness-down gabyx::brightness-down

set $clipboard gabyx::clipboard
set $clipboard-menu gabyx::clipboard-menu

set $notifications gabyx::notifications
set $notification-menu gabyx::notifications-menu

set $nightshifter gabyx::nightshifter

# Special workspaces
# Icons can be found at:
# https://www.nerdfonts.com/cheat-sheet

# Tmux workspaces.
set $ws-1 1:1:  
set $ws-2 2:2:  
set $ws-3 3:3:  
set $ws-4 4:4:  

# Shell workspaces.
set $ws-5 5:5:  
set $ws-6 6:6:  

# Applications workspaces.
set $comm-ws 7:7:  
set $ws-7 7:7:  
set $comm signal-desktop
set $comm-matrix element-desktop
set $comm-slack slack

set $mail-ws 8:8:  
set $ws-8 8:8:  
set $mail evolution

set $web-ws 9:9:  
set $ws-9 9:9:  
set $web google-chrome-stable
set $web-aux firefox

set $creds-ws 10:0:  󱕴
set $ws-10 10:0:  󱕴
set $creds bitwarden

# Default output display names.
# If other setups are used.
set $primaryDispHome 'Philips Consumer Electronics Company PHL 275E2F UHB2307008083'
set $secondaryDispHome 'Dell Inc. DELL U2724DE 4TPGCP3'

set $primaryDispWork 'Dell Inc. DELL U3421WE B6V1753'
set $secondaryDispWork 'Dell Inc. DELL U3421WE B6V1753'

### ===========================================================================

# Only one file will be deployed and picked and included.
include config-private
include config-work

include config-visual
include config-idle
include config-input
include config-keybindings
include config-applications
include config-bar

include config-startup
