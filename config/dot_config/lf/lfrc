set previewer ~/.config/lf/scripts/previewer.sh
set sixel true
set shell bash

# Basic Settings
set hidden true
set ignorecase true
set icons true

# Custom Functions
cmd mkdir ${{
  printf "Directory Name: "
  read ans
  mkdir $ans
}}

cmd mkfile ${{
  printf "File Name: "
  read ans
  $EDITOR $ans
}}

cmd movefile ${{
  printf "File Name: "
  read ans
  $EDITOR $ans
}}

# Archive bindings
cmd unarchive ${{
  case "$f" in
      *.zip) unzip "$f" ;;
      *.tar.gz) tar -xzvf "$f" ;;
      *.tar.bz2) tar -xjvf "$f" ;;
      *.tar) tar -xvf "$f" ;;
      *) echo "Unsupported format" ;;
  esac
}}

# Trash bindings
cmd trash ${{
  files=$(printf "$fx" | tr '\n' ';')
  while [ "$files" ]; do
    file=${files%%;*}

    trash-put "$(basename "$file")"
    if [ "$files" = "$file" ]; then
      files=''
    else
      files="${files#*;}"
    fi
  done
}}

cmd restore_trash ${{
  trash-restore
}}

cmd mimeopen ${{
    xdg-open "$f"
}}

cmd remove ${{
  files=()
  if [ -n "$fx"  ]; then
    readarray -t files < <(echo "$fx")
  fi

  files_vis=()
  if [ -n "$fv"  ]; then
    readarray -t files_vis < <(echo "$fv")
  fi
  files+=("${files_vis[@]}")

  filesEcho=$(printf "  - '%s'\n" "${files[@]}")
  printf "Remove the following files\n$filesEcho\nRemove '${#files[@]}' files? [N/y]: "
  read ans

  echo

  if [ "$ans" = "y" ]; then
    rm -r "${files[@]}"
  fi
}}

# Bindings
map d
map m

map au unarchive

# Basic Functions
map <esc> updir
map O $$EDITOR_READONLY "$f"
map o mimeopen
map . set hidden!
map dd trash
map dr restore_trash
map Dd remove
map p paste
map x cut
map y copy
map R reload
map mm mark-save
map mf mkfile
map md mkdir
map C clear

# Movement
map gh cd ~
map gD cd ~/Documents
map gd cd ~/Downloads
map gp cd ~/Pictures
map gr cd /persist/repos
map gc cd ~/.config
map gx cd ~/.local/share/chezmoi
map gt cd ~/.local/share/Trash/files
