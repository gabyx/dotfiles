// config-outputs.kdl
// Output and workspace configuration — translated from:
//   config-outputs, config-private, config-work, config-workspaces
//
// niri workspaces are per-output. Named workspaces can be pinned to outputs.
// Mirrors sway's `workspace $ws-N output $display` directives.
//
// Two profiles are provided below: HOME and WORK.
// Activate one by symlinking or copying to config-outputs-active.kdl and
// including it, or simply uncomment the relevant block.

// ── Output definitions ────────────────────────────────────────────────────────

// VM fallback (mirrors: output Virtual-1 resolution 1600x900)
// output "Virtual-1" {
//     mode "1600x900"
// }

// ── HOME profile ──────────────────────────────────────────────────────────────
// Primary:   Philips PHL 275E2F  (was $primaryDispHome)
// Secondary: Dell U2724DE        (was $secondaryDispHome)

output "Philips Consumer Electronics Company PHL 275E2F UHB2307008083" {
    // Add position/mode/scale as needed, e.g.:
    // mode "2560x1440"
    // scale 1.0
    // position x=0 y=0
}

output "Dell Inc. DELL U2724DE 4TPGCP3" {
    // position x=2560 y=0
}

// ── WORK profile ──────────────────────────────────────────────────────────────
// Primary:   Dell U3421WE  (both outputs are the same model in sway config)
// Secondary: Dell U3421WE

// output "Dell Inc. DELL U3421WE B6V1753" {
//     // position x=0 y=0
// }

// ── Workspace → output pinning ────────────────────────────────────────────────
// Mirrors sway config-workspaces workspace assignments.
//
// niri workspace pinning syntax (niri ≥ 0.1.x):
//   workspace "name" { open-on-output "output name"; }
//
// HOME assignments (comment out for WORK):

workspace "ws-1" { open-on-output "Philips Consumer Electronics Company PHL 275E2F UHB2307008083"; }
workspace "ws-2" { open-on-output "Philips Consumer Electronics Company PHL 275E2F UHB2307008083"; }
workspace "ws-3" { open-on-output "Philips Consumer Electronics Company PHL 275E2F UHB2307008083"; }
workspace "ws-4" { open-on-output "Philips Consumer Electronics Company PHL 275E2F UHB2307008083"; }
workspace "ws-5" { open-on-output "Philips Consumer Electronics Company PHL 275E2F UHB2307008083"; }
workspace "ws-6" { open-on-output "Philips Consumer Electronics Company PHL 275E2F UHB2307008083"; }

// Special workspaces on secondary display.
workspace "ws-7-comm"   { open-on-output "Dell Inc. DELL U2724DE 4TPGCP3"; }
workspace "ws-8-mail"   { open-on-output "Dell Inc. DELL U2724DE 4TPGCP3"; }
workspace "ws-9-web"    { open-on-output "Dell Inc. DELL U2724DE 4TPGCP3"; }
workspace "ws-10-creds" { open-on-output "Dell Inc. DELL U2724DE 4TPGCP3"; }

// WORK assignments (uncomment and comment HOME block above):
// workspace "ws-1" { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-2" { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-3" { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-4" { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-5" { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-6" { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-7-comm"   { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-8-mail"   { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-9-web"    { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }
// workspace "ws-10-creds" { open-on-output "Dell Inc. DELL U3421WE B6V1753"; }

// ── Notes ─────────────────────────────────────────────────────────────────────
// sway's `workspace "Empty" output eDP-1` (to prevent ws collision on laptop
// screen) has no direct niri equivalent. niri creates workspaces dynamically
// per output so collision is not an issue.
